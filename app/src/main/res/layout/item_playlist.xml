<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/media_library_horizontal_indent"
    android:layout_marginHorizontal="@dimen/header_outer_indent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/playlistCover"
        android:layout_width="0dp"
        android:layout_height="0dp"
        style="@style/CoverMainShapeableImageView"
        android:layout_marginTop="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@color/blue"
        />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/playlistName"
        style="@style/ItemPlaylistTextView"
        android:layout_marginTop="@dimen/item_playlist_content_indent_vertical"
        app:layout_constraintTop_toBottomOf="@id/playlistCover"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Название плейлиста"
        />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/playlistTracksCount"
        style="@style/ItemPlaylistTextView"
        app:layout_constraintTop_toBottomOf="@id/playlistName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="N треков"
        />

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingHorizontal="@dimen/search_track_inner_indent_horizontal"
    android:paddingVertical="@dimen/search_track_inner_indent_vertical"
    android:clickable="true">
    
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/playlistCover"
        android:layout_width="@dimen/search_track_image_size"
        android:layout_height="@dimen/search_track_image_size"
        android:layout_gravity="start"
        android:layout_marginStart="1dp"
        android:scaleType="centerCrop"
        app:shapeAppearance="@style/BaseRounded"
        tools:src="@drawable/ph_track_45"/>
    
    <TextView
        android:id="@+id/playlistName"
        style="@style/SearchTrackTextView"
        android:layout_marginStart="@dimen/search_track_text_start_indent"
        android:layout_marginTop="6dp"
        android:textColor="?attr/colorOnPrimary"
        android:textSize="@dimen/regular_text_size"
        tools:text="Best songs 2026"/>

    <TextView
        android:id="@+id/playlistTracksCount"
        style="@style/SearchTrackTextView"
        android:layout_gravity="start"
        android:layout_marginStart="@dimen/search_track_text_start_indent"
        android:layout_marginTop="26dp"
        tools:text="0 треков"
        />

</FrameLayout>